# Copy this to .env.local for local dev, and add the same values
# in Vercel under Project Settings > Environment Variables.
# Never commit your actual .env.local file.

# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# From your Supabase project: Settings > API
SUPABASE_URL=
# Use the "service_role" key here, NOT the anon/public key.
# This stays server-side only, inside api/ functions.
SUPABASE_SERVICE_KEY=
